# Copy this to .env on the production server and fill in real values

# Database
DB_NAME=lakezone_erp
DB_USER=lakezone
DB_PASS=CHANGE_ME_STRONG_PASSWORD

# Django
SECRET_KEY=CHANGE_ME_LONG_RANDOM_STRING_50_CHARS
DJANGO_SETTINGS_MODULE=config.settings.prod
ALLOWED_HOSTS=erp.lakezone.ke,www.erp.lakezone.ke
CORS_ALLOWED_ORIGINS=https://erp.lakezone.ke

# Database URL (used by Django)
DATABASE_URL=postgresql://lakezone:CHANGE_ME_STRONG_PASSWORD@db:5432/lakezone_erp

# Redis
REDIS_URL=redis://redis:6379/0

# Email (optional)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=noreply@lakezone.ke
